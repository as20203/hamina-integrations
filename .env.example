DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
DIRECT_DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Redis Configuration
# In Docker Compose, backend services override this to redis://redis:6379 (internal, no host port).
# Backend on host + Redis in Docker: publish Redis in compose or use redis://127.0.0.1:<mapped-port>
REDIS_URL=redis://127.0.0.1:6379
REDIS_CLUSTER=false
REDIS_PASSWORD=

# Cache Configuration
CACHE_FALLBACK_TTL_MINUTES=10
REDIS_HEALTH_CHECK_INTERVAL_MS=30000

# Bull Board Configuration
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme

# Queue Configuration
MIST_QUEUE_CONCURRENCY=5

# Mist API throttling (server-side mistFetch — rolling windows)
# Defaults: 300/min, 5000/hour, 10 concurrent (see MistRateLimiter)
MIST_MAX_REQUESTS_PER_MINUTE=300
MIST_MAX_REQUESTS_PER_HOUR=5000