# Next.js BFF → Express (server-side only). Browser never uses this.
# Local: http://127.0.0.1:4000  |  Docker Compose: http://backend:4000
BACKEND_INTERNAL_URL=http://127.0.0.1:4000
# Optional; only for links that must open the API in the browser (avoid Docker-only hostnames here)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Mist (used by backend at runtime; keep out of NEXT_PUBLIC_*)
MIST_API_KEY=
MIST_API_BASE_URL=https://api.mist.com
MIST_ORG_ID=
# Optional dev fallback; production uses site id from URL (/site/[siteId]/...)
MIST_SITE_ID=
