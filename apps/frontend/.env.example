# Next.js BFF → Express (server-side only). Set this in Docker Compose; browser uses same-origin /api/*.
# Local (backend on host): http://127.0.0.1:4000
# Docker Compose: http://backend:4000 (service name; backend port is NOT published to the host)
BACKEND_INTERNAL_URL=http://127.0.0.1:4000
# Optional fallback for server-side if BACKEND_INTERNAL_URL is unset. Do NOT use Docker hostnames
# (e.g. http://backend:4000) here—they break in the browser if ever referenced client-side.
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Redis — read by the backend container from this file, but docker-compose.yml sets
# REDIS_URL=redis://redis:6379 (internal) for backend/backend-build, overriding any value here.
# For backend on host only: REDIS_URL=redis://127.0.0.1:6379

# Mist (used by backend at runtime; keep out of NEXT_PUBLIC_*)
MIST_API_KEY=
MIST_API_BASE_URL=https://api.mist.com
# Optional WebSocket base for live stats only (default: api.mist.com → wss://api-ws.mist.com per Juniper docs)
# MIST_WS_BASE_URL=wss://api-ws.eu.mist.com
MIST_ORG_ID=
# Optional dev fallback; production uses site id from URL (/site/[siteId]/...)
MIST_SITE_ID=
