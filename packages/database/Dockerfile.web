# syntax=docker/dockerfile:1
FROM node:22-alpine AS base

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD true

FROM base AS builder
RUN apk update
RUN apk add --no-cache libc6-compat \
    chromium \
    nss \
    freetype \
    freetype-dev \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    nodejs \
    yarn \
    postgresql-client

ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

WORKDIR /app

RUN --mount=type=cache,target=/root/.npm \
    npm config set fetch-retries 20 \
  && npm config set fetch-retry-mintimeout 30000 \
  && npm config set fetch-retry-maxtimeout 180000 \
  && npm config set fetch-timeout 600000 \
  && (npm install turbo --global \
    || (echo "turbo install failed; retry 1/2 in 45s..." && sleep 45 && npm install turbo --global) \
    || (echo "turbo install failed; retry 2/2 in 90s..." && sleep 90 && npm install turbo --global))

COPY . .

RUN turbo prune backend --docker

FROM base AS installer
RUN apk update
RUN apk add --no-cache libc6-compat \
    chromium \
    nss \
    freetype \
    freetype-dev \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    nodejs \
    yarn \
    postgresql-client

WORKDIR /app

COPY --from=builder /app/out/json/ .
RUN --mount=type=cache,target=/root/.npm \
    npm config set fetch-retries 20 \
  && npm config set fetch-retry-mintimeout 30000 \
  && npm config set fetch-retry-maxtimeout 180000 \
  && npm config set fetch-timeout 600000 \
  && (npm install --frozen-lockfile \
    || (echo "npm install --frozen-lockfile failed; retry 1/2 in 45s..." && sleep 45 && npm install --frozen-lockfile) \
    || (echo "npm install --frozen-lockfile failed; retry 2/2 in 90s..." && sleep 90 && npm install --frozen-lockfile))

EXPOSE 3000
